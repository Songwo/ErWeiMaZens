{
  "name": "erweimazens",
  "private": true,
  "workspaces": [
    "frontend",
    "workers"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:workers": "cd workers && npx wrangler dev",
    "build:frontend": "cd frontend && npm run build",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:workers\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
